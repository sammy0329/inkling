#!/bin/sh
# 커밋 메시지 첫 줄이 Conventional Commits 형식인지 검증. (ADR-0005)
first_line=$(head -n1 "$1")

# merge/revert/fixup 커밋은 통과
case "$first_line" in
  "Merge "*|"Revert "*|fixup!*|squash!*) exit 0 ;;
esac

if printf '%s' "$first_line" | grep -Eq '^(feat|fix|docs|chore|refactor|test|style|perf|ci|build)(\([a-z0-9-]+\))?!?: .+'; then
  exit 0
fi

echo "✗ 커밋 메시지 형식 위반 (Conventional Commits — ADR-0005)"
echo "  형식: <type>(<scope>): <subject>"
echo "  type: feat|fix|docs|chore|refactor|test|style|perf|ci|build"
echo "  예:   feat(db): posts 스키마 추가"
echo "  받은 첫 줄: $first_line"
exit 1
